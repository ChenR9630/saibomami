# NEKO.SYNC Production Configuration
# Copy this to .env.local and fill in your values.

# --- Deployment Mode ---
# Set to "true" for production (binds 127.0.0.1 only, enforces Secure cookies, etc.)
PRODUCTION=false

# --- Server Ports ---
# Production: Node binds 127.0.0.1:8000 behind Nginx
# Development: HTTPS on 8443 (LAN), HTTP on 8000 (localhost), cert server on 8080
PORT=8443
CERT_PORT=8080
LOCAL_PORT=8000

# --- Logging ---
LOG_LEVEL=info

# --- Rate Limiting ---
# Per-IP requests per minute (global API limit)
RATE_LIMIT_RPM=60
# Per-IP auth attempts per minute (login, register, send-code)
AUTH_RATE_LIMIT_RPM=10

# --- Image Provider ---
# "volcengine" or "openai"
IMAGE_PROVIDER=volcengine

# --- Volcengine ARK API ---
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
ARK_CHAT_MODEL=doubao-1-5-pro-32k-250115

# --- Standard View Mode ---
# "auto" (default) or "passthrough" (for local debugging with pre-prepared images)
STANDARD_VIEW_MODE=auto

# --- OpenAI Fallback ---
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# --- Tripo 3D Identity Reconstruction ---
TRIPO_API_KEY=your_tripo_api_key_here
TRIPO_STUDIO_URL=https://studio.tripo3d.com
TRIPO_API_BASE_URL=https://openapi.tripo3d.com/v3
TRIPO_MODEL_VERSION=v3.1-20260211
TRIPO_QUAD_FACE_LIMIT=8000

# --- WeChat OAuth ---
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# Must match the authorized redirect domain in WeChat Open Platform.
# Example: https://your-domain.com/api/auth/wechat/callback
# In production, set this explicitly — do NOT rely on Host header auto-detection.
WECHAT_REDIRECT_URI=

# --- Payment ---
CUSTOM_TWIN_PRICE_CNY=18.8
# Required for manual payment confirmation endpoint.
PAYMENT_ADMIN_TOKEN=change_this_long_random_token

# --- SSE Clients ---
MAX_SSE_CLIENTS=100
